{
  "name": "api",
  "version": "1.0.0",
  "type": "module",
  "description": "Data migration scripts for PocketBase",
  "scripts": {
    "migrate": "node migrate-data.js",
    "migrate:dry-run": "node migrate-data.js --dry-run",
    "dev": "node --trace-deprecation --env-file=.env src/main.js",
    "start": "node --env-file=.env src/main.js",
    "lint": "eslint . --quiet"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "pocketbase": "^0.26.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^15.14.0"
  }
}